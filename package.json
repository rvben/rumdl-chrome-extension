{
  "name": "rumdl-chrome-extension",
  "version": "1.0.0",
  "description": "Real-time Markdown linting with auto-fix for GitHub, GitLab, and Reddit",
  "type": "module",
  "scripts": {
    "build": "npm run build:wasm && node scripts/build.js",
    "build:wasm": "node scripts/copy-wasm.js",
    "watch": "node scripts/build.js && node scripts/build.js --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "package": "npm run build && rm -f rumdl-extension.zip && zip -r rumdl-extension.zip manifest.json dist/ icons/ popup/ wasm/ -x '*.svg'"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@types/chrome": "^0.1.36",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.2",
    "jsdom": "^28.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}
