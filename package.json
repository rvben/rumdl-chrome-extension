{
  "name": "rumdl-chrome-extension",
  "version": "1.0.0",
  "description": "Real-time Markdown linting with auto-fix for GitHub and GitLab",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "watch": "node scripts/build.js && node scripts/build.js --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node tests/e2e/extension.test.mjs",
    "test:smoke": "node tests/smoke/selector-check.mjs",
    "package": "npm run build && rm -f rumdl-extension.zip && zip -r rumdl-extension.zip manifest.json dist/ icons/ popup/ -x '*.svg'"
  },
  "dependencies": {
    "rumdl-wasm": "0.1.49"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.36",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.2",
    "jsdom": "^28.0.0",
    "playwright": "^1.58.2",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}
