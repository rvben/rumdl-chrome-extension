{
  "manifest_version": 3,
  "name": "rumdl — Markdown Linter",
  "short_name": "rumdl",
  "version": "1.0.0",
  "description": "Real-time Markdown linting with auto-fix for GitHub and GitLab.",
  "homepage_url": "https://github.com/rvben/rumdl-chrome-extension",
  "minimum_chrome_version": "121",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://gitlab.com/*"
  ],
  "background": {
    "service_worker": "dist/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*",
        "https://gitlab.com/*"
      ],
      "js": ["dist/content/content-script.js"],
      "css": ["dist/content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "rumdl — Markdown Linter",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "web_accessible_resources": [
    {
      "resources": ["wasm/*"],
      "matches": [
        "https://github.com/*",
        "https://gitlab.com/*"
      ]
    }
  ]
}
