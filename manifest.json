{
  "manifest_version": 3,
  "name": "rumdl",
  "version": "1.0.0",
  "description": "Real-time Markdown linting with auto-fix for GitHub, GitLab, and Reddit. Powered by the rumdl Rust linter.",
  "minimum_chrome_version": "90",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://gitlab.com/*",
    "https://*.gitlab.io/*",
    "https://www.reddit.com/*",
    "https://old.reddit.com/*"
  ],
  "background": {
    "service_worker": "dist/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*",
        "https://gitlab.com/*",
        "https://*.gitlab.io/*",
        "https://www.reddit.com/*",
        "https://old.reddit.com/*"
      ],
      "js": ["dist/content/content-script.js"],
      "css": ["dist/content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "web_accessible_resources": [
    {
      "resources": ["wasm/*"],
      "matches": [
        "https://github.com/*",
        "https://gitlab.com/*",
        "https://*.gitlab.io/*",
        "https://www.reddit.com/*",
        "https://old.reddit.com/*"
      ]
    }
  ]
}
